# Environment variables (example)

# SMTP configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false # true if using port 465
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# From address used in the email
EMAIL_FROM="no-reply@yourdomain.com"

# Where uploaded CVs are sent (defaults to info@nemukula.co.za)
RECIPIENT_EMAIL=info@nemukula.co.za

# Optional: port to run the Node server
PORT=3000
